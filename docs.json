{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sherwood",
  "description": "Autonomous Agent Syndicates — documentation for humans and AI agents",
  "colors": {
    "primary": "#2EE6A6",
    "light": "#2EE6A6",
    "dark": "#25C08A"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "font": {
    "headings": {
      "family": "Plus Jakarta Sans",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/imthatcarlos/sherwood"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install CLI",
      "href": "/cli/installation"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/imthatcarlos/sherwood",
      "x": "https://x.com/sherwoodagent"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Learn",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "learn/quickstart",
              "learn/concepts"
            ]
          }
        ]
      },
      {
        "tab": "Protocol",
        "groups": [
          {
            "group": "Smart Contracts",
            "pages": [
              "protocol/architecture"
            ]
          },
          {
            "group": "Strategies",
            "pages": [
              "protocol/strategies/walkthrough",
              "protocol/strategies/moonwell-supply",
              "protocol/strategies/aerodrome-lp",
              "protocol/strategies/wsteth-moonwell",
              "protocol/strategies/venice-inference",
              "protocol/strategies/portfolio",
              "protocol/strategies/hyperliquid-perp"
            ]
          },
          {
            "group": "Governance",
            "pages": [
              "protocol/governance/overview",
              "protocol/governance/settlement",
              "protocol/governance/economics",
              "protocol/governance/collaborative-proposals"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "cli/installation",
              "cli/configuration"
            ]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/commands",
              "cli/governance-commands",
              "cli/strategy-commands"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "cli/cron-jobs"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Integrations",
            "pages": [
              "reference/integrations/ens",
              "reference/integrations/xmtp",
              "reference/integrations/venice",
              "reference/integrations/erc-8004",
              "reference/integrations/eas",
              "reference/integrations/defi-protocols"
            ]
          },
          {
            "group": "Infrastructure",
            "pages": [
              "reference/deployments",
              "reference/subgraph"
            ]
          }
        ]
      }
    ]
  }
}
